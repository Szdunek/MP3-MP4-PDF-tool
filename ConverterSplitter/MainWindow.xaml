<Window x:Class="ConverterSplitter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ConverterSplitter.ViewModels"
        xmlns:views="clr-namespace:ConverterSplitter.Views"
        xmlns:svc="clr-namespace:ConverterSplitter.Services"
        Title="Converter Splitter"
        Height="750" Width="1150"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        TextElement.Foreground="#E0E0E0"
        TextElement.FontWeight="Regular"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0"
                      CornerRadius="16" />
    </WindowChrome.WindowChrome>

    <Border Background="#121220" CornerRadius="16" BorderBrush="#2A2A3E" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ─── Sidebar ─── -->
            <Border Grid.Column="0" Background="#181828" CornerRadius="16,0,0,16">
                <DockPanel>
                    <!-- App Title (draggable area) -->
                    <Border DockPanel.Dock="Top" MouseLeftButtonDown="OnTitleBarDrag" Background="Transparent">
                        <StackPanel Margin="20,20,20,16">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#2A1F4E" CornerRadius="10" Padding="8" Margin="0,0,12,0">
                                    <materialDesign:PackIcon Kind="ToolboxOutline" Width="22" Height="22"
                                                             Foreground="#B39DDB" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Converter" FontSize="20" FontWeight="Bold" Foreground="#E0E0E0"
                                               LineHeight="22" />
                                    <TextBlock Text="Splitter" FontSize="20" FontWeight="Bold" Foreground="#B39DDB"
                                               LineHeight="22" Margin="0,-2,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <Border Height="1" Background="#22FFFFFF" Margin="0,14,0,0" CornerRadius="1" />
                        </StackPanel>
                    </Border>

                    <!-- Bottom: Update + Version + Language -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,14">
                        <!-- Update Banner -->
                        <Button Command="{Binding ShowUpdateCommand}"
                                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}"
                                Cursor="Hand" Margin="0,0,0,10"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalContentAlignment="Stretch" Padding="0">
                            <Border Background="#1A80CBC4" CornerRadius="10" Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowUpBoldCircleOutline" Width="18" Height="18"
                                                             Foreground="#80CBC4" VerticalAlignment="Center" />
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock Text="{Binding [update_available], Source={x:Static svc:Loc.I}}"
                                                   FontSize="12" Foreground="#80CBC4" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding UpdateVersionText}" FontSize="10"
                                                   Foreground="#5580CBC4" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Language toggle -->
                        <Button Command="{Binding ToggleLanguageCommand}" Cursor="Hand" Margin="0,0,0,10"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalContentAlignment="Stretch" Padding="0">
                            <Border Background="#15FFFFFF" CornerRadius="8" Padding="10,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="Web" Width="18" Height="18"
                                                             Foreground="#B39DDB" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding [lang_switch], Source={x:Static svc:Loc.I}, Mode=OneWay}"
                                               Foreground="#AAFFFFFF" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center" />
                                    <Border Grid.Column="2" Background="#2A1F4E" CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="{Binding LanguageLabel, Mode=OneWay}" FontSize="12"
                                                   Foreground="#B39DDB" FontWeight="Bold" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Button>

                        <!-- Version -->
                        <TextBlock FontSize="11" Foreground="#44FFFFFF" Margin="8,0,0,0">
                            <Run Text="{Binding CurrentVersionText, Mode=OneWay}" />
                            <Run Text=" | &#169; DogSoft" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Navigation -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                        <StackPanel Margin="10,0">
                            <TextBlock Text="{Binding [nav_media], Source={x:Static svc:Loc.I}}"
                                       FontSize="10" FontWeight="Bold" Foreground="#44FFFFFF"
                                       Margin="16,4,0,8" />

                            <RadioButton Style="{StaticResource NavButton}"
                                         IsChecked="{Binding IsVideoSelected}" GroupName="Nav">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="VideoOutline" Width="18" Height="18"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding [nav_video_mp3], Source={x:Static svc:Loc.I}}"
                                               Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavButton}"
                                         IsChecked="{Binding IsAudioCutterSelected}" GroupName="Nav">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentCut" Width="18" Height="18"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding [nav_audio_cutter], Source={x:Static svc:Loc.I}}"
                                               Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavButton}"
                                         IsChecked="{Binding IsAudioConverterSelected}" GroupName="Nav">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="SwapHorizontal" Width="18" Height="18"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding [nav_audio_converter], Source={x:Static svc:Loc.I}}"
                                               Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <Border Height="1" Background="#11FFFFFF" Margin="14,10" CornerRadius="1" />

                            <TextBlock Text="{Binding [nav_documents], Source={x:Static svc:Loc.I}}"
                                       FontSize="10" FontWeight="Bold" Foreground="#44FFFFFF"
                                       Margin="16,0,0,8" />

                            <RadioButton Style="{StaticResource NavButton}"
                                         IsChecked="{Binding IsPdfMergeSelected}" GroupName="Nav">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilePdfBox" Width="18" Height="18"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding [nav_pdf_merge], Source={x:Static svc:Loc.I}}"
                                               Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavButton}"
                                         IsChecked="{Binding IsPdfSplitSelected}" GroupName="Nav">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CallSplit" Width="18" Height="18"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding [nav_pdf_split], Source={x:Static svc:Loc.I}}"
                                               Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <Border Height="1" Background="#11FFFFFF" Margin="14,10" CornerRadius="1" />

                            <TextBlock Text="{Binding [nav_images], Source={x:Static svc:Loc.I}}"
                                       FontSize="10" FontWeight="Bold" Foreground="#44FFFFFF"
                                       Margin="16,0,0,8" />

                            <RadioButton Style="{StaticResource NavButton}"
                                         IsChecked="{Binding IsImageConverterSelected}" GroupName="Nav">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ImageOutline" Width="18" Height="18"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding [nav_image_converter], Source={x:Static svc:Loc.I}}"
                                               Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ─── Content Area ─── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Custom Titlebar -->
                <Border Grid.Row="0" Background="#0DFFFFFF" MouseLeftButtonDown="OnTitleBarDrag"
                        CornerRadius="0,16,0,0">
                    <Grid Height="40" Margin="16,0,4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                   FontSize="12" Foreground="#55FFFFFF"
                                   Text="Converter Splitter" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Click="OnMinimize" Style="{StaticResource MaterialDesignFlatButton}"
                                    Width="40" Height="32" Padding="0"
                                    Foreground="#88FFFFFF" WindowChrome.IsHitTestVisibleInChrome="True">
                                <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16" />
                            </Button>
                            <Button Click="OnMaximize" Style="{StaticResource MaterialDesignFlatButton}"
                                    Width="40" Height="32" Padding="0"
                                    Foreground="#88FFFFFF" WindowChrome.IsHitTestVisibleInChrome="True">
                                <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16" />
                            </Button>
                            <Button Click="OnClose" Style="{StaticResource MaterialDesignFlatButton}"
                                    Width="40" Height="32" Padding="0"
                                    Foreground="#88FFFFFF" WindowChrome.IsHitTestVisibleInChrome="True">
                                <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Views with fade-in animation -->
                <Grid Grid.Row="1" Margin="16,8,16,16">
                    <Grid.Resources>
                        <Style TargetType="UserControl">
                            <Style.Triggers>
                                <Trigger Property="Visibility" Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0" To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                    From="12,8,0,0" To="0" Duration="0:0:0.3">
                                                    <ThicknessAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ThicknessAnimation.EasingFunction>
                                                </ThicknessAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Resources>
                    <views:VideoConverterView Visibility="{Binding DataContext.IsVideoSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                    <views:AudioCutterView Visibility="{Binding DataContext.IsAudioCutterSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                    <views:AudioConverterView Visibility="{Binding DataContext.IsAudioConverterSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                    <views:PdfMergerView Visibility="{Binding DataContext.IsPdfMergeSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                    <views:PdfSplitterView Visibility="{Binding DataContext.IsPdfSplitSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                    <views:ImageConverterView Visibility="{Binding DataContext.IsImageConverterSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
