<UserControl x:Class="ConverterSplitter.Views.ImageConverterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ConverterSplitter.ViewModels"
             xmlns:conv="clr-namespace:ConverterSplitter.Converters"
             xmlns:svc="clr-namespace:ConverterSplitter.Services">
    <UserControl.DataContext>
        <vm:ImageConverterViewModel />
    </UserControl.DataContext>
    <UserControl.Resources>
        <conv:FileSizeConverter x:Key="FileSizeConv" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">
            <TextBlock Text="Image Converter &amp; Resizer" Style="{StaticResource SectionTitle}" FontSize="24" />
            <TextBlock Text="Convert images between formats and optionally resize them."
                       Foreground="#88FFFFFF" Margin="0,0,0,20" />

            <!-- Drop Zone -->
            <Border Style="{StaticResource DropZone}" AllowDrop="True"
                    Drop="OnDrop" DragOver="OnDragOver"
                    Visibility="{Binding IsConverting, Converter={StaticResource InvBoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="ImageMultipleOutline" Width="48" Height="48"
                                             HorizontalAlignment="Center" Foreground="#55FFFFFF" />
                    <TextBlock Text="Drag &amp; drop images here" FontSize="16"
                               Foreground="#88FFFFFF" HorizontalAlignment="Center" Margin="0,12,0,8" />
                    <TextBlock Text="PNG, JPG, BMP, GIF, WebP, TIFF" FontSize="11"
                               Foreground="#44FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,12" />
                    <Button Content="Browse Images" Command="{Binding BrowseFilesCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- File List -->
            <ItemsControl ItemsSource="{Binding Files}" Margin="0,16,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource FileListItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontSize="14" Foreground="#E0E0E0" />
                                    <TextBlock Foreground="#55FFFFFF" FontSize="11">
                                        <Run Text="{Binding Width}" /><Run Text="x" /><Run Text="{Binding Height}" />
                                        <Run Text=" | " />
                                        <Run Text="{Binding FileSize, Converter={StaticResource FileSizeConv}, Mode=OneWay}" />
                                        <Run Text=" | " /><Run Text="{Binding Status}" />
                                    </TextBlock>
                                </StackPanel>
                                <materialDesign:PackIcon Grid.Column="1" Kind="ImageOutline"
                                                         Foreground="#4DB6AC" Width="20" Height="20"
                                                         VerticalAlignment="Center" Margin="8,0" />
                                <Button Grid.Column="2"
                                        Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28" Padding="0">
                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Settings -->
            <Border Style="{StaticResource CardBorder}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Conversion Settings" Style="{StaticResource SectionTitle}" FontSize="16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Output Format" Foreground="#88FFFFFF" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{x:Static svc:ImageService.OutputFormats}"
                                      SelectedItem="{Binding SelectedFormat}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Quality (JPEG/WebP)" Foreground="#88FFFFFF" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <Slider Width="150" Minimum="10" Maximum="100" Value="{Binding Quality}"
                                        VerticalAlignment="Center" Foreground="#B39DDB" />
                                <TextBlock Text="{Binding Quality, StringFormat={}{0}%}"
                                           Foreground="#88FFFFFF" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Resize Options -->
                    <CheckBox Content="Resize images" IsChecked="{Binding ResizeEnabled}"
                              Margin="0,16,0,8" Foreground="#E0E0E0" />
                    <Grid Visibility="{Binding ResizeEnabled, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Width (px)" Foreground="#88FFFFFF" Margin="0,0,0,4" />
                            <TextBox Text="{Binding TargetWidth}" Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="x" Foreground="#55FFFFFF" FontSize="18"
                                   VerticalAlignment="Center" Margin="4,16,4,0" />
                        <StackPanel Grid.Column="2" Margin="8,0">
                            <TextBlock Text="Height (px)" Foreground="#88FFFFFF" Margin="0,0,0,4" />
                            <TextBox Text="{Binding TargetHeight}" Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </StackPanel>
                        <CheckBox Grid.Column="3" Content="Keep aspect ratio"
                                  IsChecked="{Binding KeepAspectRatio}"
                                  VerticalAlignment="Center" Margin="12,16,0,0" Foreground="#E0E0E0" />
                    </Grid>

                    <!-- Output Folder -->
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Output Folder (optional)" Foreground="#88FFFFFF" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding OutputFolder}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Same as source" IsReadOnly="True" />
                            <Button Grid.Column="1" Content="..." Margin="8,0,0,0"
                                    Command="{Binding BrowseOutputFolderCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" Padding="8,0" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" Foreground="#80CBC4" FontSize="13" />
                    <ProgressBar Value="{Binding OverallProgress}" Maximum="100" Height="4"
                                 Margin="0,8,16,0" Foreground="#B39DDB"
                                 Visibility="{Binding IsConverting, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
                <Button Grid.Column="1" Content="Clear All" Margin="0,0,8,0"
                        Command="{Binding ClearFilesCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                <Button Grid.Column="2" Command="{Binding ConvertAllCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#7E57C2" BorderBrush="#7E57C2">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ImageEditOutline" VerticalAlignment="Center" />
                        <TextBlock Text="Convert All" Margin="8,0,0,0" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
