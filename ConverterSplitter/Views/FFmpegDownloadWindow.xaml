<Window x:Class="ConverterSplitter.Views.FFmpegDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="FFmpeg Setup"
        Height="280" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        TextElement.Foreground="#E0E0E0"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="32">
        <StackPanel VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                <materialDesign:PackIcon Kind="Download" Width="32" Height="32"
                                         Foreground="#B39DDB" VerticalAlignment="Center" />
                <TextBlock Text="FFmpeg Required" FontSize="22" FontWeight="Bold"
                           Foreground="#E0E0E0" Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock x:Name="StatusText" Text="FFmpeg is needed for video and audio processing. Click Download to install it automatically."
                       TextWrapping="Wrap" TextAlignment="Center" Foreground="#88FFFFFF"
                       FontSize="13" Margin="0,0,0,20" />

            <ProgressBar x:Name="ProgressBar" Height="8" Value="0" Maximum="100"
                         Foreground="#B39DDB" Visibility="Collapsed" Margin="0,0,0,8" />

            <TextBlock x:Name="ProgressText" Text="" FontSize="11"
                       Foreground="#80CBC4" HorizontalAlignment="Center"
                       Margin="0,0,0,16" />

            <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="DownloadButton" Content="Download FFmpeg (~80 MB)"
                        Click="OnDownloadClick"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#7E57C2" BorderBrush="#7E57C2"
                        Margin="0,0,8,0" Padding="24,8" />
                <Button x:Name="SkipButton" Content="Skip"
                        Click="OnSkipClick"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Padding="24,8" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
