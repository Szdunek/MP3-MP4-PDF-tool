<UserControl x:Class="ConverterSplitter.Views.PdfMergerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ConverterSplitter.ViewModels"
             xmlns:conv="clr-namespace:ConverterSplitter.Converters">
    <UserControl.DataContext>
        <vm:PdfMergerViewModel />
    </UserControl.DataContext>
    <UserControl.Resources>
        <conv:FileSizeConverter x:Key="FileSizeConv" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">
            <TextBlock Text="PDF Merge" Style="{StaticResource SectionTitle}" FontSize="24" />
            <TextBlock Text="Combine multiple PDF files into one. Drag to reorder."
                       Foreground="#88FFFFFF" Margin="0,0,0,20" />

            <!-- Drop Zone -->
            <Border Style="{StaticResource DropZone}" AllowDrop="True"
                    Drop="OnDrop" DragOver="OnDragOver">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="FilePdfBox" Width="48" Height="48"
                                             HorizontalAlignment="Center" Foreground="#55FFFFFF" />
                    <TextBlock Text="Drag &amp; drop PDF files here" FontSize="16"
                               Foreground="#88FFFFFF" HorizontalAlignment="Center" Margin="0,12,0,8" />
                    <Button Content="Browse PDFs" Command="{Binding BrowseFilesCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- File List -->
            <ItemsControl ItemsSource="{Binding Files}" Margin="0,16,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource FileListItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Reorder Buttons -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <Button Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Width="24" Height="20" Padding="0">
                                        <materialDesign:PackIcon Kind="ChevronUp" Width="14" Height="14" />
                                    </Button>
                                    <Button Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Width="24" Height="20" Padding="0">
                                        <materialDesign:PackIcon Kind="ChevronDown" Width="14" Height="14" />
                                    </Button>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontSize="14" Foreground="#E0E0E0" />
                                    <TextBlock Foreground="#55FFFFFF" FontSize="11">
                                        <Run Text="{Binding PageCount}" />
                                        <Run Text=" pages | " />
                                        <Run Text="{Binding FileSize, Converter={StaticResource FileSizeConv}, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>

                                <materialDesign:PackIcon Grid.Column="2" Kind="FilePdfBox"
                                                         Foreground="#EF5350" Width="20" Height="20"
                                                         VerticalAlignment="Center" Margin="8,0" />

                                <Button Grid.Column="3"
                                        Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Width="28" Height="28" Padding="0">
                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Actions -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusText}" Foreground="#80CBC4"
                           FontSize="13" VerticalAlignment="Center" />

                <Button Grid.Column="1" Content="Clear All" Margin="0,0,8,0"
                        Command="{Binding ClearFilesCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                <Button Grid.Column="2" Command="{Binding MergeCommand}"
                        IsEnabled="{Binding IsMerging, Converter={StaticResource InvBoolToVis}}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#7E57C2" BorderBrush="#7E57C2">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Merge" VerticalAlignment="Center" />
                        <TextBlock Text="Merge PDFs" Margin="8,0,0,0" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
