<UserControl x:Class="ConverterSplitter.Controls.WaveformControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ClipToBounds="True">
    <Grid x:Name="MainGrid">
        <!-- Waveform Image -->
        <Image x:Name="WaveformImage" Stretch="Fill" />

        <!-- Selection overlay -->
        <Canvas x:Name="SelectionCanvas">
            <!-- Left dimmer (before selection) -->
            <Rectangle x:Name="LeftDimmer" Fill="#88000000" Canvas.Top="0" />
            <!-- Right dimmer (after selection) -->
            <Rectangle x:Name="RightDimmer" Fill="#88000000" Canvas.Top="0" />

            <!-- Selection highlight -->
            <Rectangle x:Name="SelectionRect" Canvas.Top="0" Opacity="0.3" />

            <!-- Selection handles -->
            <Rectangle x:Name="StartHandle" Width="4" Canvas.Top="0"
                       Cursor="SizeWE" Fill="#B39DDB" />
            <Rectangle x:Name="EndHandle" Width="4" Canvas.Top="0"
                       Cursor="SizeWE" Fill="#B39DDB" />

            <!-- Playback position line -->
            <Line x:Name="PositionLine" StrokeThickness="2"
                  Y1="0" Stroke="#80CBC4" />
        </Canvas>
    </Grid>
</UserControl>
